rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------------------
    // GLOBAL SAFETY NET
    // ------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ------------------------------------------------------------------------
    // CORE PRIMITIVES
    // ------------------------------------------------------------------------
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // ------------------------------------------------------------------------
    // VALIDATION BLUEPRINTS
    // ------------------------------------------------------------------------
    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'details', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 200 &&
             data.details is string && data.details.size() > 0 && data.details.size() <= 2000 &&
             data.createdAt == request.time;
    }

    // ------------------------------------------------------------------------
    // COLLECTIONS
    // ------------------------------------------------------------------------

    // /messages/{messageId}
    match /messages/{messageId} {
      // Anyone can submit a contact message (even unauthenticated, as it's a public portfolio contact form)
      // Allow create if validation passes.
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      
      // No one can read/update/delete these messages from the client side 
      // (Server-side admins could check them via admin SDK/console)
      allow read, update, delete: if false;
    }
  }
}
